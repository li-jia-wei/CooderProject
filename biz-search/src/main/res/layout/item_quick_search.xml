<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="@dimen/dp_46"
	android:gravity="center_vertical"
	android:paddingHorizontal="@dimen/dp_20">
	
	<com.cooder.library.ui.view.IconFontTextView
		android:id="@+id/icon"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginEnd="@dimen/dp_20"
		android:text="@string/ic_search"
		android:textColor="@color/quick_search_icon"
		android:textSize="@dimen/sp_24" />
	
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical">
		
		<TextView
			android:id="@+id/content"
			android:layout_width="match_parent"
			android:layout_height="0dp"
			android:layout_weight="1"
			android:ellipsize="end"
			android:gravity="center_vertical"
			android:singleLine="true"
			android:textColor="@color/quick_search_text"
			tools:text="搜索内容" />
		
		<View
			android:id="@+id/underline"
			android:layout_width="match_parent"
			android:layout_height="@dimen/dp_1"
			android:background="@color/quick_search_underline" />
	
	</LinearLayout>

</LinearLayout>
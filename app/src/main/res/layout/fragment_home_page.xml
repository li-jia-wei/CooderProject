<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/white"
	android:orientation="vertical"
	tools:context=".fragment.home.HomePageFragment">
	
	<com.cooder.cooder.project.common.ui.view.IconFontTextView
		android:layout_width="match_parent"
		android:layout_height="@dimen/dp_35"
		android:layout_margin="@dimen/dp_16"
		android:background="@drawable/shape_home_page_search"
		android:gravity="center"
		android:text="@string/home_search_hint"
		android:textColor="@color/rgb_9fa"
		android:textSize="@dimen/sp_14" />
	
	<com.cooder.cooder.ui.tab.top.CoTabTopLayout
		android:id="@+id/tab_top_layout"
		android:layout_width="match_parent"
		android:layout_height="@dimen/dp_45" />
	
	<androidx.viewpager.widget.ViewPager
		android:id="@+id/view_pager"
		android:layout_width="match_parent"
		android:layout_height="match_parent" />

</LinearLayout>
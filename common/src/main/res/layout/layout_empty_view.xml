<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:gravity="center"
	android:orientation="vertical"
	tools:context=".ui.view.EmptyView">

	<ImageView
		android:id="@+id/empty_image"
		android:layout_width="@dimen/dp_100"
		android:layout_height="@dimen/dp_100"
		android:visibility="gone"
		tools:ignore="ContentDescription" />

	<com.cooder.cooder.project.common.ui.view.IconFontTextView
		android:id="@+id/empty_icon"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/empty_view_icon"
		android:textColor="@color/darker_gray"
		android:textSize="@dimen/sp_70"
		android:visibility="gone"
		app:typeface="@string/ic_alibaba_path"
		tools:visibility="visible" />

	<TextView
		android:id="@+id/empty_title"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="@dimen/dp_20"
		android:layout_marginBottom="@dimen/dp_10"
		android:text="@string/empty_view_title"
		android:textColor="@color/darker_gray"
		android:textSize="@dimen/sp_16"
		android:visibility="gone"
		tools:visibility="visible" />

	<LinearLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginBottom="@dimen/dp_20"
		android:gravity="center_vertical">

		<TextView
			android:id="@+id/empty_desc"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/empty_view_text"
			android:textColor="@color/darker_gray"
			android:textSize="@dimen/sp_14" />

		<com.cooder.cooder.project.common.ui.view.IconFontTextView
			android:id="@+id/empty_help_action"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginStart="@dimen/dp_6"
			android:gravity="center"
			android:text="@string/ic_prompt"
			android:textColor="@color/primary"
			android:textSize="@dimen/sp_20"
			android:visibility="gone"
			app:typeface="@string/ic_alibaba_path"
			tools:visibility="visible" />

	</LinearLayout>

	<Button
		android:id="@+id/empty_refresh"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:backgroundTint="@android:color/holo_red_light"
		android:text="@string/empty_view_refresh"
		android:textColor="@color/white" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	tools:context=".fragment.category.CategoryFragment">
	
	<com.cooder.library.ui.navigation.CoNavigationBar
		android:layout_width="match_parent"
		android:layout_height="@dimen/dp_48"
		app:titleText="分类"
		app:titleTextSize="@dimen/sp_17"
		app:underlineEnabled="false" />
	
	<com.cooder.library.ui.search.CoSearchView
		android:id="@+id/search_view"
		android:layout_width="match_parent"
		android:layout_height="@dimen/dp_60"
		app:searchEnabled="false"
		app:hintText="@string/home_search_hint" />
	
	<View
		android:layout_width="match_parent"
		android:layout_height="@dimen/dp_1"
		android:layout_marginTop="@dimen/dp_10"
		android:background="@color/rgb_eee" />
	
	<com.cooder.library.ui.slider.CoSliderView
		android:id="@+id/slider_view"
		android:layout_width="match_parent"
		android:layout_height="match_parent" />

</LinearLayout>
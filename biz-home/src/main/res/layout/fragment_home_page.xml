<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:background="@color/white"
	android:orientation="vertical"
	tools:context=".fragment.home.HomePageFragment">
	
	<com.cooder.library.ui.search.CoSearchView
		android:id="@+id/search_view"
		android:layout_width="match_parent"
		android:layout_height="@dimen/dp_60"
		app:searchEnabled="false"
		app:hintText="@string/home_search_hint" />
	
	<com.cooder.library.ui.tab.top.CoTabTopLayout
		android:id="@+id/tab_top_layout"
		android:layout_width="match_parent"
		android:layout_height="@dimen/dp_45" />
	
	<androidx.viewpager.widget.ViewPager
		android:id="@+id/view_pager"
		android:layout_width="match_parent"
		android:layout_height="match_parent" />

</LinearLayout>